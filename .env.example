# Copia este archivo como .env y rellena tus valores reales

# Anthropic Claude API Key
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Telegram Bot Token
# Créalo con @BotFather en Telegram y copia el token aquí
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Telegram Chat ID
# Envía un mensaje a tu bot y visita:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# El campo "chat.id" es tu CHAT_ID (puede ser negativo si es un grupo)
TELEGRAM_CHAT_ID=8286701014
